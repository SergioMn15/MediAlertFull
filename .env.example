# SERVER
PORT=3000

# DATABASE (PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/medialert?sslmode=require

# SSL certificate only if your provider requires it
# DB_CA_CERT=-----BEGIN CERTIFICATE-----\nMIIE...\n-----END CERTIFICATE-----
# DB_CA_CERT_BASE64=MIIE...base64...

DB_POOL_MAX=3

# AUTH
JWT_SECRET=change_this_secret_in_production

# REMINDER SCHEDULER
REMINDER_SCHEDULER_ENABLED=true
REMINDER_INTERVAL_MS=10000

# EMAIL NOTIFICATIONS (Resend)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REMINDER_FROM_EMAIL=MediAlert <no-reply@yourdomain.com>

# PYWHATKIT WHATSAPP
# Requiere Python, navegador disponible y sesion iniciada en WhatsApp Web
# PYTHON_BIN=python
# PYWHATKIT_WAIT_TIME=20
# PYWHATKIT_CLOSE_TAB=true
# PYWHATKIT_CLOSE_TIME=3
# PYWHATKIT_TIMEOUT_MS=120000

# TWILIO SMS
# Si quieres conservar SMS por Twilio, configura estas variables
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+523121234567
